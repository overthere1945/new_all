Import('env')
env.LoadSoftwareUnits()
env = env.Clone()


if env['CHIPSET'] in ['atherton']:
    SRCPATH = '${BUILD_ROOT}/qsh/qsh_ss/microstack'
    BUILDTAG = 'CORE_SSC_ADSP_USER'
    Transport = 'IPC'
    env.Append(CFLAGS = ' -DUART_BUILD_V1')    
elif env['CHIPSET'] in ['balsam']:
    SRCPATH = '${BUILD_ROOT}/bt/microstack'
    BUILDTAG = 'BT_ADSP_USER'
    Transport = 'I3C'
else:
    SRCPATH = '${BUILD_ROOT}/bt/microstack'
    BUILDTAG = 'BT_ADSP_USER'
    Transport = 'UART'


env.VariantDir('${BUILDPATH}', SRCPATH, duplicate=0)

#-------------------------------------------------------------------------------
# Internal depends within free rtos
#-------------------------------------------------------------------------------
core_public_apis = [
       'KERNEL',
       'SERVICES',
       'POWER',
       'DAL',
       'BUSES',
       'DEBUGTOOLS',
       'SYSTEMDRIVERS',
       'PRODUCTS',
       'DIAG',
       'DEBUGTRACE',
       'MPROC',
]

platform_public_apis = [
       'PLATFORM_LIBS',
       'MOD_TABLE',
       'QAIC',
       'STDDEF',
       'REMOTE',
       'HAPSDK',
]

env.RequirePublicApi(core_public_apis, area='core')
env.RequirePublicApi(platform_public_apis, area='platform')

env.RequirePublicApi(['MICRO_STACK_API'])
env.RequirePublicApi(['MICRO_STACK_INT'])
if Transport == 'I3C':
    if env.PathExists('${BUILD_ROOT}/qsh_drivers/qsh_ble/bt/build'):
        env.RequirePublicApi(['QSH_BLE_BT_PUBLIC_APIS'])

#-------------------------------------------------------------------------------
# Compilation flags
#-------------------------------------------------------------------------------
if Transport == 'UART':
    env.Append(CFLAGS = ' -DSYN_BT_HOST_TRANSPORT=2')
elif Transport == 'I3C':
    env.Append(CFLAGS = ' -DSYN_BT_HOST_TRANSPORT=3')
else:
    env.Append(CFLAGS = ' -DSYN_BT_HOST_TRANSPORT=1')
#env.Append(CFLAGS = ' -DSYN_IPC_UNIT_TEST')


