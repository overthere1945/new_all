MICRO_STACK_SRC = LIB_SRC+FRW_SRC+BS_SRC+COMMON_SRC+RFCOMM_SRC+L2CAP_SRC+DM_SRC+ATT_SRC+GATT_SRC+BMM_SRC+HCI_ARBITER_SRC+OFFLOAD_SRC+ADV_SCAN_SRC+TEST_SRC

if Transport == 'UART':
    MICRO_STACK_SRC += UART_SRC
elif Transport == 'I3C':
    MICRO_STACK_SRC += I3C_SRC
else :
    MICRO_STACK_SRC += IPC_SRC
        
microstack_lib = env.AddLibrary(BUILDTAG, '${BUILDPATH}/micro_stack', MICRO_STACK_SRC)

if 'BT_ADSP_USER' in BUILDTAG and 'USES_MEMSEG' in env:
    env.TagLibraryForMemorySegment(BUILDTAG, 'bt', microstack_lib)

